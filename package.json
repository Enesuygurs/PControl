{
  "name": "pcontrol",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:local": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:start": "electron .",
    "build:app": "next build && electron-builder --win"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "systeminformation": "^5.31.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.enesuygurs.pcontrol",
    "productName": "PControl",
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/**/*",
      "public/**/*",
      "main.js",
      "package.json",
      "src/lib/system-control.ts"
    ],
    "asar": false
  }
}
